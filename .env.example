# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env

# --- OpenAI (obrigatorio) ---
OPENAI_API_KEY=

# --- Qdrant ---
# Defaults ja funcionam com o docker-compose (localhost:6333).
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Langfuse (opcional - observabilidade) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
